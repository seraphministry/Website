    split: {
      name: "The Split",
      declaration: "[YOUR DECLARATION FOR THE SPLIT — INSERT HERE]\n\nThis is the field where you speak to the person living between a public faith and a private reality. The gap between who they perform and who they actually are is producing shame they cannot shake. God is targeting the false self — not to expose them, but to free them. Speak to the mercy in what He is doing.",
      invitation: "The Burning Ones is for people who are exhausted by the gap. What you bring in private is exactly what is welcome here.",
      isPlaceholder: true
    }
  };

  /* Secondary condition acknowledgments — most common pairings */
  const SECONDARY_TEXT = {
    "numb-withdrawn":    "There is also something beneath the numbness that once knew closeness and lost it. God is moving on that too.",
    "numb-split":        "There is also a gap between what you present and what you actually carry. God sees both versions.",
    "unsettled-numb":    "There is also a quiet beneath the restlessness — a place that has stopped expecting to feel much. God is in that too.",
    "unsettled-split":   "There is also something in you that performs stability while something else burns underneath. God is targeting both.",
    "withdrawn-numb":    "There is also a hollowness beneath the guardedness — a place that has gone quiet from waiting. God has not gone quiet.",
