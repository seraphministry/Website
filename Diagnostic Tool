    "numb-unsettled":    "There is also a restlessness beneath the numbness that has not fully gone quiet. God is stirring something.",
    "unsettled-withdrawn": "There is also a guardedness beneath the hunger — a part of you that wants more but has learned not to reach. God is in the reach.",
    "withdrawn-unsettled": "There is also an unsettled quality beneath the withdrawal — something that knows it was made for more. God has not forgotten that.",
    "split-unsettled":   "There is also a hunger in you that the performance has been trying to contain. God is targeting the container."
  };

  /* ============================================================
     DIAGNOSTIC ENGINE
  ============================================================ */

  const QUESTIONS = [
    {
      text: "When you think about God right now — honestly, not how you're supposed to feel — what's closest to the truth?",
      answers: [
        { text: "I believe He's real. I just don't feel anything when I think about Him anymore.", condition: "numb" },
        { text: "Honestly? There was a time He felt close. Now there's a distance I didn't choose and haven't been able to close.", condition: "withdrawn" },
        { text: "Something in me wants more of Him than I know what to do with. I can't explain it.", condition: "unsettled" },
        { text: "In certain moments, genuinely close. In others, like I'm talking to Someone who can see exactly what I'm hiding.", condition: "split" }
      ]
    },
    {
      text: "If the people closest to you could see your spiritual life exactly as it is — not how you present it — what would they find?",
      answers: [
        { text: "Probably the same thing they already see. I'm not hiding anything. I'm just not feeling much either.", condition: "numb" },
        { text: "Someone who is hungry for something they can't fully articulate yet.", condition: "unsettled" },
        { text: "Someone more guarded than they let on. There are rooms I don't let anyone into.", condition: "withdrawn" },
        { text: "A significant gap between who I am when I'm seen and who I am when I'm not.", condition: "split" }
      ]
    },
    {
      text: "Has there ever been a moment where God felt genuinely real to you — not something you believed, but something you actually experienced?",
      answers: [
        { text: "Not really. Or if there was, I can't access it anymore. It's like trying to remember a dream.", condition: "numb" },
        { text: "Yes. And then something happened — disappointment, hurt, silence — and something in me closed. I haven't fully opened it since.", condition: "withdrawn" },
        { text: "Yes — and it left me wanting something I haven't been able to find since. Like a hunger that nothing satisfies.", condition: "unsettled" },
        { text: "There have been moments. But they feel distant from the version of me that shows up in public. Like they happened to someone else.", condition: "split" }
      ]
    },
    {
      text: "Right now, without thinking about it theologically — where do you carry your spiritual life in your body?",
      answers: [
        { text: "Nowhere I can feel. It lives in my head. It stopped reaching the rest of me a long time ago.", condition: "numb" },
        { text: "In my chest mostly. Like something pressing outward that hasn't found a way out yet.", condition: "unsettled" },
        { text: "Behind my sternum. A dull ache that flares up when I get too close to something real.", condition: "withdrawn" },
        { text: "In my throat. The thing I almost say but don't. The version of me I almost show but pull back.", condition: "split" }
      ]
    },
    {
      text: "If God moved in your life right now — specifically, tangibly — what would you most need that movement to do?",
      answers: [
        { text: "Wake something up in me. Prove to me that what I've believed all this time is actually real and not just habit.", condition: "numb", weight: 2 },
        { text: "Release whatever is building inside me. Give it a name, a direction, a purpose.", condition: "unsettled", weight: 2 },
        { text: "Reach past the place where I stopped letting Him in. Get through the wall without me having to explain how it got there.", condition: "withdrawn", weight: 2 },
        { text: "See all of me — the private version, the real one — and not turn away.", condition: "split", weight: 2 }
      ]
    }
  ];

  /* Shuffle answer order for each question */
  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  let scores = { numb: 0, unsettled: 0, withdrawn: 0, split: 0 };
  let currentQ = 0;
  let shuffledAnswers = [];
  let primaryCondition = '';
  let secondaryCondition = '';

  function startDiagnostic() {
    scores = { numb: 0, unsettled: 0, withdrawn: 0, split: 0 };
    currentQ = 0;
    shuffledAnswers = QUESTIONS.map(q => shuffle(q.answers));
    transitionTo('screen-questions');
    renderQuestion();
  }

  function buildProgressDots() {
    const dots = document.getElementById('progress-dots');
    dots.innerHTML = '';
    for (let i = 0; i < QUESTIONS.length; i++) {
      const d = document.createElement('div');
      d.className = 'dot' + (i === currentQ ? ' active' : i < currentQ ? ' done' : '');
      dots.appendChild(d);
    }
  }

  function renderQuestion() {
    buildProgressDots();
    const q = QUESTIONS[currentQ];
    document.getElementById('question-text').textContent = q.text;
    const container = document.getElementById('answers-container');
    container.innerHTML = '';
    shuffledAnswers[currentQ].forEach((ans, idx) => {
      const btn = document.createElement('button');
      btn.className = 'answer-btn';
      btn.textContent = ans.text;
      btn.setAttribute('data-condition', ans.condition);
      btn.setAttribute('data-weight', ans.weight || 1);
      btn.onclick = () => selectAnswer(btn);
      container.appendChild(btn);
    });
  }

  function selectAnswer(btn) {
    if (btn.classList.contains('selected')) return;
    document.querySelectorAll('.answer-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    const condition = btn.getAttribute('data-condition');
    const weight = parseInt(btn.getAttribute('data-weight'));
    scores[condition] += weight;
    setTimeout(() => {
      currentQ++;
      if (currentQ < QUESTIONS.length) {
        renderQuestion();
        const qs = document.getElementById('screen-questions');
        qs.style.animation = 'none';
        void qs.offsetWidth;
        qs.style.animation = 'screenIn 0.4s ease forwards';
      } else {
        calculateResult();
        transitionTo('screen-transition');
      }
    }, 380);
  }

  function calculateResult() {
    const sorted = Object.entries(scores).sort((a, b) => b[1] - a[1]);
    primaryCondition = sorted[0][0];

    /* Tiebreaker: if top two scores are equal, Q5 answer wins */
    if (sorted[0][1] === sorted[1][1]) {
      const q5answer = shuffledAnswers[4].find(a => document.querySelector(`[data-condition="${a.condition}"].selected`));
      if (q5answer) primaryCondition = q5answer.condition;
    }

    secondaryCondition = sorted.find(s => s[0] !== primaryCondition)?.[0] || '';
  }

  function handleConsent(ready) {
    if (ready) {
      showResult();
    } else {
      transitionTo('screen-hesitation');
    }
  }

  function showResult() {
    const content = RESULT_CONTENT[primaryCondition];
    const conditionEl = document.getElementById('result-condition-name');
    const declarationEl = document.getElementById('result-declaration');
    const secondaryEl = document.getElementById('result-secondary');
    const invitationEl = document.getElementById('result-invitation');

    conditionEl.textContent = content.name;

    declarationEl.textContent = content.declaration;
    if (content.isPlaceholder) {
      declarationEl.classList.add('placeholder-text');
    } else {
      declarationEl.classList.remove('placeholder-text');
    }

    const pairKey = primaryCondition + '-' + secondaryCondition;
    const secondaryText = SECONDARY_TEXT[pairKey] || '';
    secondaryEl.textContent = secondaryText;
    secondaryEl.style.display = secondaryText ? 'block' : 'none';

    invitationEl.textContent = content.invitation;

    transitionTo('screen-result');
  }

  function joinCommunity() {
    /* REPLACE THIS URL WITH YOUR COMMUNITY LINK */
    const communityUrl = 'https://YOUR-COMMUNITY-LINK-HERE';
    window.open(communityUrl, '_blank');
    setTimeout(() => transitionTo('screen-postjoin'), 300);
  }

  function shareResult() {
    const content = RESULT_CONTENT[primaryCondition];
    const shareUrl = window.location.href;
    const shareText = `God is targeting "${content.name}" in my life right now. Find out what He's targeting in yours →`;

    if (navigator.share) {
      navigator.share({ title: 'Seraph Ministry Diagnostic', text: shareText, url: shareUrl });
    } else {
      const encoded = encodeURIComponent(shareText + ' ' + shareUrl);
      window.open('https://twitter.com/intent/tweet?text=' + encoded, '_blank');
    }
  }

  function selectPost(btn) {
    document.querySelectorAll('.post-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    document.getElementById('post-continue').style.display = 'inline-flex';
  }

  function completeDiagnostic() {
    transitionTo('screen-complete');
  }

  /* ── SCREEN TRANSITION ── */
  function transitionTo(nextId) {
    const current = document.querySelector('.screen.active');
    const next = document.getElementById(nextId);
    if (!current || !next || current === next) return;

    current.classList.add('leaving');
    current.classList.remove('active');

    setTimeout(() => {
      current.classList.remove('leaving');
      current.style.display = 'none';
      next.style.display = 'flex';
      next.classList.add('active');
      next.style.animation = 'none';
      void next.offsetWidth;
      next.style.animation = 'screenIn 0.5s ease forwards';
      window.scrollTo(0, 0);
    }, 280);
  }
</script>
</body>
</html>
